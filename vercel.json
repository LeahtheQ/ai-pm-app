{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_APP_ENV": "production"
  },
  "functions": {
    "api/*.js": {
      "maxDuration": 60,
      "includeFiles": ".claude/agents/**"
    }
  }
}
